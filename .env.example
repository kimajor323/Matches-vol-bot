# .env.example

# Deriv API configuration
DERIV_APP_ID=example_app_id
DERIV_API_TOKEN=example_api_token
DERIV_ACCOUNT_ID=example_account_id

# Trading configuration
TRADING_SYMBOL=example_symbol
TRADING_AMOUNT=100
TRADING_TYPE=example_type

# Risk management
RISK_MANAGEMENT_ENABLED=true
RISK_LIMIT=50

# Model configuration
MODEL_TYPE=example_model_type
MODEL_VERSION=1.0

# Logging settings
LOG_LEVEL=info
LOG_FILE_PATH=/var/log/matches_vol_bot.log